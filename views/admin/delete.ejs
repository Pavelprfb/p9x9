<!DOCTYPE html>
<html>
<head>
  <title>Delete Posts</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', sans-serif;
    }

    body {
      background: linear-gradient(135deg, #141e30, #243b55);
      padding: 20px;
      color: #fff;
    }

    h1 {
      text-align: center;
      margin-bottom: 30px;
      font-weight: 600;
    }

    .card {
      background: rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(12px);
      padding: 15px;
      margin-bottom: 20px;
      border-radius: 12px;
      box-shadow: 0 8px 25px rgba(0,0,0,0.4);
      display: flex;
      gap: 15px;
      align-items: center;
      border: 1px solid rgba(255,255,255,0.08);
      transition: 0.3s ease;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    .card img {
      width: 130px;
      height: 90px;
      object-fit: cover;
      border-radius: 8px;
    }

    .content {
      flex: 1;
    }

    .content h3 {
      margin-bottom: 8px;
      font-size: 18px;
      color: #ffffff;
    }

    .content p {
      font-size: 13px;
      color: #ddd;
      margin: 3px 0;
    }

    .delete-btn {
      background: linear-gradient(45deg, #ff416c, #ff4b2b);
      color: #fff;
      border: none;
      padding: 10px 18px;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      transition: 0.3s;
    }

    .delete-btn:hover {
      transform: scale(1.05);
      box-shadow: 0 5px 15px rgba(255, 75, 43, 0.4);
    }

    .no-data {
      text-align: center;
      margin-top: 30px;
      color: #ccc;
    }

    @media (max-width: 768px) {
      .card {
        flex-direction: column;
        align-items: flex-start;
      }

      .card img {
        width: 100%;
        height: auto;
      }

      .delete-btn {
        width: 100%;
        margin-top: 10px;
      }
    }

  </style>
</head>
<body>

  <h1>All Posts - Delete Panel</h1>

  <% if(allData.length === 0){ %>
      <p class="no-data">No Data Found</p>
  <% } %>

  <% allData.forEach((data) => { %>
    
    <div class="card">
      
      <img src="<%= data.imageLink %>" alt="Image">

      <div class="content">
        <h3><%= data.title %></h3>
        <p><strong>Route:</strong> <%= data.routeName %></p>
        <p><strong>Duration:</strong> <%= data.duration %></p>
        <p><strong>Total View:</strong> <%= data.totalView %></p>
        <p><strong>Category:</strong> <%= data.category.join(', ') %></p>
      </div>

      <form action="/admin/delete" method="POST" 
        onsubmit="return confirm('Are you sure to delete this post?');">
        <input type="hidden" name="routeName" value="<%= data.routeName %>">
        <button type="submit" class="delete-btn">Delete</button>
      </form>

    </div>

  <% }) %>

</body>
</html>