<!DOCTYPE html>  
<html lang="en">  
<head>  
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">  
<title>All Data Forms</title>  

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:'Segoe UI', sans-serif;
}

body{
  background: linear-gradient(135deg, #141e30, #243b55);
  padding:20px;
  color:#fff;
}

h1{
  text-align:center;
  margin-bottom:25px;
}

.cards-container{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
  gap:20px;
}

/* card */
.data-card{
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(12px);
  border-radius:15px;
  padding:15px;
  border:1px solid rgba(255,255,255,0.08);
  box-shadow:0 8px 20px rgba(0,0,0,0.4);
}

.data-card img{
  width:100%;
  height:180px;
  object-fit:cover;
  border-radius:10px;
  margin-bottom:10px;
}

/* input */
.input-group{
  display:flex;
  gap:6px;
  margin-bottom:8px;
}

input{
  flex:1;
  padding:8px;
  border-radius:6px;
  border:none;
  background: rgba(255,255,255,0.1);
  color:#fff;
}

input:focus{
  outline:1px solid #00c6ff;
}

/* buttons */
.btns{
  display:flex;
  gap:5px;
}

.btns button{
  padding:8px;
  border:none;
  border-radius:6px;
  cursor:pointer;
  font-size:12px;
  font-weight:600;
}

.copy{background:#4CAF50;color:#fff;}
.paste{background:#ffa726;color:#fff;}
.clear{background:#ff4141;color:#fff;}

.submit-btn{
  width:100%;
  padding:10px;
  margin-top:5px;
  border:none;
  border-radius:8px;
  background: linear-gradient(45deg, #00c6ff, #0072ff);
  color:#fff;
  font-weight:600;
}

.hide-btn{
  width:100%;
  padding:10px;
  margin-top:6px;
  border:none;
  border-radius:8px;
  background: linear-gradient(45deg, #ff416c, #ff4b2b);
  color:#fff;
  cursor:pointer;
}
</style>
</head>

<body>

<h1>All Data Entries</h1>

<div class="cards-container">

<% allData.forEach((data) => { %>

<form class="data-card" id="card-<%= data.id %>"
action="https://movieb-f42x.onrender.com/add/p9x9-signle-data"
method="post">

<img src="<%= data.imageLink %>" alt=""/>

<!-- Route -->
<div class="input-group">
  <input id="route_<%= data.id %>" name="id" value="<%= data.routeName %>">
  <div class="btns">
    <button type="button" class="copy" onclick="copyInput(this)">Copy</button>
    <button type="button" class="paste" onclick="pasteInput(this)">Paste</button>
    <button type="button" class="clear" onclick="clearInput(this)">Clear</button>
  </div>
</div>

<!-- Title -->
<div class="input-group">
  <input id="title_<%= data.id %>" name="hadding" value="<%= data.title %>">
  <div class="btns">
    <button type="button" class="copy" onclick="copyInput(this)">Copy</button>
    <button type="button" class="paste" onclick="pasteInput(this)">Paste</button>
    <button type="button" class="clear" onclick="clearInput(this)">Clear</button>
  </div>
</div>

<!-- Image -->
<div class="input-group">
  <input id="img_<%= data.id %>" name="img" value="<%= data.imageLink %>">
  <div class="btns">
    <button type="button" class="copy" onclick="copyInput(this)">Copy</button>
    <button type="button" class="paste" onclick="pasteInput(this)">Paste</button>
    <button type="button" class="clear" onclick="clearInput(this)">Clear</button>
  </div>
</div>

<!-- Video -->
<div class="input-group">
  <input id="video_<%= data.id %>" name="play" value="<%= data.videoLink %>">
  <div class="btns">
    <button type="button" class="copy" onclick="copyInput(this)">Copy</button>
    <button type="button" class="paste" onclick="pasteInput(this)">Paste</button>
    <button type="button" class="clear" onclick="clearInput(this)">Clear</button>
  </div>
</div>

<button class="submit-btn" type="submit">Submit</button>

<button type="button" class="hide-btn" onclick="hideData('<%= data.id %>')">
  Hide
</button>

</form>

<% }) %>

</div>

<script>

/* ======================
   OLD COOKIE SYSTEM (UNCHANGED)
====================== */

// Set cookie to hide card
function hideData(id) {
  let card = document.getElementById("card-" + id);
  if (card) card.style.display = "none";

  let d = new Date();
  d.setTime(d.getTime() + (365*24*60*60*1000));
  document.cookie = `hide_${id}=true; expires=${d.toUTCString()}; path=/`;
}

function getCookie(name) {
  let value = "; " + document.cookie;
  let parts = value.split("; " + name + "=");
  if (parts.length === 2) return parts.pop().split(";").shift();
}

window.onload = function() {
  <% allData.forEach((data) => { %>
    if(getCookie("hide_<%= data.id %>") === "true") {
      let card = document.getElementById("card-<%= data.id %>");
      if(card) card.style.display = "none";
    }
  <% }) %>
};

/* ======================
   COPY / PASTE / CLEAR (NEW)
====================== */

function copyInput(btn){
  const input = btn.closest(".input-group").querySelector("input");
  navigator.clipboard.writeText(input.value);
}

async function pasteInput(btn){
  const input = btn.closest(".input-group").querySelector("input");
  try{
    input.value = await navigator.clipboard.readText();
  }catch{}
}

function clearInput(btn){
  const input = btn.closest(".input-group").querySelector("input");
  input.value = "";
}

</script>

</body>
</html>