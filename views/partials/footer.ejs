<div class="footer-container">
  <footer>
    <div class="footer-content">
      <div class="footer-left">
        <h2><a href="/" alt="Home logo" class="footer-logo">P9X9</a></h2>
        <p>© <%= new Date().getFullYear() %> P9X9. All rights reserved.</p>
        <a href="/privacy" alt="Privacy">Privacy and Policy</a>
        <br/>
        <a href="/terms" alt="Terms">Terms and Conditions</a>
      </div>
      
      <div class="footer-right">
        <div class="footer-links">
          <a href="/" alt="Home logo">Home</a>
          <a href="<%= telegramLink %>">Telegram</a>
        </div>
        <div class="footer-social">
          <a href="<%= smartLink %>" alt="Social"><i class="fab fa-facebook-f"></i></a>
          <a href="<%= smartLink %>" alt="Social"><i class="fab fa-twitter"></i></a>
          <a href="<%= smartLink %>" alt="Social"><i class="fab fa-instagram"></i></a>
        </div>
      </div>
    </div>
  </footer>
</div>

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
/* Footer Container */
.footer-container {
  background: #0f172a;
  color: #e5e7eb;
  font-family: Arial, sans-serif;
  padding: 30px 20px;
  border-top: 1px solid #1e293b;
}

footer {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 20px;
}

.footer-left h2 {
  margin: 0 0 8px 0;
  font-size: 24px;
}

.footer-left .footer-logo {
  color: #fbbf24;
  text-decoration: none;
  transition: all 0.3s ease;
}

.footer-left .footer-logo:hover {
  color: #ffd84d;
  transform: translateY(-2px);
}

.footer-left p {
  font-size: 14px;
  color: #9ca3af;
}

.footer-right {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.footer-links a {
  color: #e5e7eb;
  text-decoration: none;
  margin-right: 15px;
  font-weight: 500;
  transition: all 0.3s ease;
}

.footer-links a:hover {
  color: #fbbf24;
}

.footer-social a {
  color: #e5e7eb;
  margin-right: 12px;
  font-size: 18px;
  transition: all 0.3s ease;
}

.footer-social a:hover {
  color: #fbbf24;
}

/* Responsive */
@media (max-width: 768px) {
  footer {
    flex-direction: column;
    align-items: flex-start;
  }
  
  .footer-right {
    flex-direction: row;
    justify-content: space-between;
    width: 100%;
    flex-wrap: wrap;
  }
  
  .footer-links {
    margin-bottom: 10px;
  }
}
</style>