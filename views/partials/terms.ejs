<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Terms and Conditions - <%= siteName %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- SEO -->
    <meta name="description" content="Official Terms and Conditions of <%= siteName %>. 18+ Adult Website.">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="https://<%= url %>/terms">
    
    <!-- SEO -->
    
    <meta name="keywords" content="<%= keywords %>" />
    <link rel="icon" href="<%= img %>"/>

    
    <!-- og tag -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="Terms and Conditions - <%= siteName %>">
    <meta property="og:url" content="<%= url %>/terms">
    <meta property="og:image" content="<%= img %>">
    <meta property="og:description" content="Official Terms and Conditions of <%= siteName %>. 18+ Adult Website." />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="Terms and Conditions - <%= siteName %>">
    <meta name="twitter:site" content="@<%= url %>/terms">
    <meta name="twitter:description"  content="Official Terms and Conditions of <%= siteName %>. 18+ Adult Website.">
    <meta name="twitter:image" content="<%= img %>">
    <meta name="twitter:image:alt" content="Privacy and Policy">
    <meta name="twitter:card" content="summary_large_image" />
    
    
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #000;
            color: #f1f1f1;
            font-family: Arial, sans-serif;
            line-height: 1.7;
        }

        header {
            background: #111;
            padding: 15px 20px;
            border-bottom: 2px solid #ff0000;
        }

        header a {
            color: #ff0000;
            text-decoration: none;
            font-size: 20px;
            font-weight: bold;
        }

        .container {
            max-width: 900px;
            margin: 40px auto;
            padding: 20px;
        }

        .card {
            background: #111;
            padding: 30px;
            border-radius: 8px;
            border: 1px solid #222;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.1);
        }

        h1 {
            color: #ff0000;
            margin-bottom: 15px;
        }

        h2 {
            color: #ff4d4d;
            margin-top: 25px;
            margin-bottom: 10px;
        }

        ul {
            margin-left: 20px;
            margin-bottom: 15px;
        }

        a {
            color: #ff0000;
            text-decoration: none;
        }

        a:hover {
            text-decoration: underline;
            color: #ff4d4d;
        }


        @media (max-width: 768px) {
            .container {
                padding: 15px;
            }
            .card {
                padding: 20px;
            }
        }
    </style>
</head>

<body>


<%- include('header') %>

<div class="container">
