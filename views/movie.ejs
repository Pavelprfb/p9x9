<!DOCTYPE html>
<html lang="bn">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= data.hadding %></title>
  <meta name="description" content="<%= description %>">

  <!-- OG TAG -->
  <meta property="og:title" content="<%= data.hadding %>">
  <meta property="og:description" content="<%= description %>">
  <meta property="og:image" content="<%= data.img %>">
  <meta property="og:url" content="<%= url %>movie/<%= data.id %>">
  <meta property="og:type" content="video.other">

  <!-- Twitter Card -->
  <meta name="twitter:card" content="player">
  <meta name="twitter:title" content="<%= data.hadding %>">
  <meta name="twitter:description" content="<%= description %>">
  <meta name="twitter:image" content="<%= data.img %>">

  <!-- Font Awesome for Icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

  <style>
    /* Base & Reset */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      background: radial-gradient(ellipse at top, #0c0c0c 0%, #050505 100%);
      color: #fff;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      min-height: 100vh;
      overflow-x: hidden;
    }
    
    /* Animated background */
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: 
        radial-gradient(circle at 20% 30%, rgba(77, 163, 255, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(255, 77, 164, 0.03) 0%, transparent 50%),
        radial-gradient(circle at 40% 80%, rgba(255, 184, 77, 0.03) 0%, transparent 50%);
      z-index: -1;
    }
    
    .wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 20px;
      position: relative;
    }
    
    /* Movie Title */
    h1 {
      font-size: 28px;
      margin-bottom: 20px;
      color: #fff;
      font-weight: 800;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
      position: relative;
      padding-bottom: 12px;
    }
    
    h1::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100px;
      height: 4px;
      background: linear-gradient(90deg, #4da3ff, #ff4da3);
      border-radius: 2px;
    }
    
    /* Video Player Container with Center Play Button */
    .video-player-container {
      position: relative;
      width: 100%;
      border-radius: 18px;
      overflow: hidden;
      background: #000;
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(77, 163, 255, 0.2);
      border: 2px solid rgba(77, 163, 255, 0.2);
      transition: box-shadow 0.4s, border-color 0.4s;
    }
    
    .video-player-container:hover {
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.8), 0 0 40px rgba(77, 163, 255, 0.4);
      border-color: rgba(77, 163, 255, 0.5);
    }
    
    /* Video Element */
    video {
      width: 100%;
      height: auto;
      display: block;
      cursor: pointer;
    }
    
    /* Center Play/Pause Button */
    .center-play-button {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 80px;
      height: 80px;
      background: rgba(0, 0, 0, 0.7);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      opacity: 0;
      transition: all 0.3s ease;
      z-index: 10;
      border: 3px solid rgba(255, 255, 255, 0.8);
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
    }
    
    .center-play-button:hover {
      background: rgba(0, 0, 0, 0.9);
      border-color: rgba(77, 163, 255, 0.9);
      transform: translate(-50%, -50%) scale(1.1);
    }
    
    .center-play-button i {
      font-size: 36px;
      color: white;
      margin-left: 5px;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.7);
    }
    
    /* Show center button on hover and when video is paused */
    .video-player-container:hover .center-play-button,
    video:not([data-playing="true"]) + .center-play-button {
      opacity: 1;
    }
    
    /* Hide center button when video is playing (except on hover) */
    video[data-playing="true"] + .center-play-button {
      opacity: 0;
    }
    
    .video-player-container:hover video[data-playing="true"] + .center-play-button {
      opacity: 1;
    }
    
    /* Download Button - Enhanced */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin-top: 20px;
      padding: 16px 32px;
      background: linear-gradient(135deg, #e50914 0%, #b50710 100%);
      color: white;
      text-decoration: none;
      border-radius: 12px;
      font-weight: 700;
      font-size: 16px;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 8px 20px rgba(229, 9, 20, 0.3);
      border: none;
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }
    
    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.7s;
    }
    
    .btn:hover {
      background: linear-gradient(135deg, #ff1a1a 0%, #d41414 100%);
      transform: translateY(-5px);
      box-shadow: 0 15px 30px rgba(229, 9, 20, 0.5);
    }
    
    .btn:hover::before {
      left: 100%;
    }
    
    .btn:active {
      transform: translateY(-2px);
    }
    
    /* Divider */
    hr {
      margin: 40px 0;
      border: 0;
      border-top: 2px solid;
      border-image: linear-gradient(90deg, transparent, #4da3ff, #ff4da3, transparent) 1;
    }
    
    /* Suggested Videos Header */
    h2 {
      font-size: 24px;
      margin-bottom: 25px;
      font-weight: 800;
      color: #fff;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    h2::before {
      content: '🔁';
      font-size: 20px;
      filter: drop-shadow(0 0 5px rgba(77, 163, 255, 0.5));
    }
    
    /* Suggested Grid - Enhanced */
    .suggest-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 20px;
      margin-bottom: 30px;
    }
    
    .s-card {
      text-decoration: none;
      color: white;
      background: linear-gradient(145deg, #1b1b1b 0%, #0f0f0f 100%);
      border-radius: 12px;
      overflow: hidden;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 1px solid rgba(255, 255, 255, 0.05);
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
      position: relative;
      display: flex;
      flex-direction: column;
    }
    
    .s-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(135deg, rgba(77, 163, 255, 0.1) 0%, rgba(255, 77, 164, 0.1) 100%);
      opacity: 0;
      transition: opacity 0.4s;
      z-index: 1;
      pointer-events: none;
    }
    
    .s-card::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 4px;
      background: linear-gradient(90deg, #4da3ff, #ff4da3);
      transform: scaleX(0);
      transition: transform 0.4s;
      z-index: 2;
    }
    
    .s-card img {
      width: 100%;
      height: 220px;
      display: block;
      transition: transform 0.6s;
      filter: brightness(0.9);
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .s-card p {
      font-size: 15px;
      padding: 15px;
      margin: 0;
      font-weight: 600;
      line-height: 1.4;
      flex-grow: 1;
      display: flex;
      align-items: center;
      z-index: 2;
      position: relative;
    }
    
    .s-card:hover {
      transform: translateY(-10px) scale(1.03);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 30px rgba(77, 163, 255, 0.3);
      border-color: rgba(77, 163, 255, 0.4);
    }
    
    .s-card:hover::before {
      opacity: 1;
    }
    
    .s-card:hover::after {
      transform: scaleX(1);
    }
    
    .s-card:hover img {
      transform: scale(1.08);
      filter: brightness(1.1);
    }
    
    .s-card:hover p {
      color: #4da3ff;
    }
    
    /* Load More Button - Enhanced */
    .load-btn {
      width: 100%;
      margin: 30px 0 50px;
      padding: 18px;
      background: linear-gradient(135deg, #4da3ff 0%, #1a5bff 100%);
      border: none;
      color: white;
      font-size: 16px;
      font-weight: 700;
      border-radius: 12px;
      cursor: pointer;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      box-shadow: 0 10px 25px rgba(77, 163, 255, 0.3);
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      position: relative;
      overflow: hidden;
    }
    
    .load-btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.7s;
    }
    
    .load-btn:hover {
      background: linear-gradient(135deg, #5db3ff 0%, #2a6bff 100%);
      transform: translateY(-5px);
      box-shadow: 0 15px 35px rgba(77, 163, 255, 0.5);
    }
    
    .load-btn:hover::before {
      left: 100%;
    }
    
    .load-btn:disabled {
      opacity: 0.7;
      cursor: not-allowed;
      transform: none !important;
    }
    
    /* Rating Badge for Suggestions */
    .s-card .rating {
      position: absolute;
      top: 15px;
      right: 15px;
      background: linear-gradient(135deg, #ff4da3, #ff9a3d);
      color: white;
      font-weight: 800;
      font-size: 13px;
      padding: 5px 9px;
      border-radius: 8px;
      z-index: 3;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.5);
      display: flex;
      align-items: center;
      gap: 3px;
    }
    
    .s-card .rating::before {
      content: '★';
      font-size: 11px;
      color: gold;
    }
    
    /* Responsive Design */
    @media (max-width: 1024px) {
      .wrap {
        max-width: 95%;
        padding: 15px;
      }
      
      .suggest-grid {
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 18px;
      }
      
      .s-card img {
        height: 200px;
      }
      
      h1 {
        font-size: 24px;
      }
      
      .center-play-button {
        width: 70px;
        height: 70px;
      }
      
      .center-play-button i {
        font-size: 32px;
      }
    }
    
    @media (max-width: 768px) {
      .suggest-grid {
        grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
        gap: 15px;
      }
      
      .s-card img {
        height: 180px;
      }
      
      .s-card p {
        font-size: 14px;
        padding: 12px;
      }
      
      h1 {
        font-size: 22px;
      }
      
      h2 {
        font-size: 20px;
      }
      
      .btn, .load-btn {
        padding: 14px 28px;
        font-size: 15px;
      }
      
      .center-play-button {
        width: 60px;
        height: 60px;
      }
      
      .center-play-button i {
        font-size: 28px;
      }
    }
    
    @media (max-width: 480px) {
      .suggest-grid {
        grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
        gap: 12px;
      }
      
      .s-card img {
        height: 160px;
      }
      
      .s-card p {
        font-size: 13px;
        padding: 10px;
      }
      
      h1 {
        font-size: 20px;
      }
      
      h2 {
        font-size: 18px;
      }
      
      .btn, .load-btn {
        padding: 12px 24px;
        font-size: 14px;
        width: 100%;
        text-align: center;
      }
      
      .center-play-button {
        width: 50px;
        height: 50px;
      }
      
      .center-play-button i {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
<%- include('partials/header') %>



<div class="wrap">
  <h1><%= data.hadding %></h1>

  <!-- Video Player Container with Center Play Button -->
  <div class="video-player-container">
    <video
      id="mainVideo"
      controls
      nodownload
      preload="auto"
      playsinline
      poster="<%= data.img %>"
      data-playing="false">
      <source src="<%= data.play %>" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    
    <!-- Center Play/Pause Button -->
    <div class="center-play-button" id="centerPlayButton">
      <i class="fas fa-play" id="centerPlayIcon"></i>
    </div>
  </div>

  <br>

  <a
    class="btn"
    href="https://superioroptionaleveryone.com/n7zjq0qcp?key=f4ce1616a0dbd6e606504b1fa58b7fb1">
    ⬇ Download Video
  </a>
</div>

<hr style="margin:20px 0;border:0;border-top:1px solid #222">

<h2>🔁 Suggested Videos</h2>

<div class="suggest-grid" id="suggestGrid">
  <% suggested.forEach(item => { %>
    <a href="/movie/<%= item.id %>" class="s-card">
      <div class="rating"><%= (Math.random() * 2 + 8).toFixed(1) %></div>
      <img src="<%= item.img %>" loading="lazy" alt="<%= item.hadding %>">
      <p><%= item.hadding %></p>
    </a>
  <% }) %>
</div>

<button id="loadMore" class="load-btn">
  <span>See More</span>
  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
    <path d="M12 5v14M5 12l7 7 7-7"/>
  </svg>
</button>

<script>
// Video Player with Center Play Button Functionality
document.addEventListener('DOMContentLoaded', function() {
  const video = document.getElementById('mainVideo');
  const centerPlayButton = document.getElementById('centerPlayButton');
  const centerPlayIcon = document.getElementById('centerPlayIcon');
  
  // Toggle play/pause when clicking the center button
  centerPlayButton.addEventListener('click', function(e) {
    e.stopPropagation();
    toggleVideoPlayback();
  });
  
  // Toggle play/pause when clicking the video
  video.addEventListener('click', function(e) {
    e.stopPropagation();
    toggleVideoPlayback();
  });
  
  // Function to toggle video playback
  function toggleVideoPlayback() {
    if (video.paused) {
      video.play();
      video.setAttribute('data-playing', 'true');
      centerPlayIcon.className = 'fas fa-pause';
    } else {
      video.pause();
      video.setAttribute('data-playing', 'false');
      centerPlayIcon.className = 'fas fa-play';
    }
  }
  
  // Update center button icon based on video state
  video.addEventListener('play', function() {
    video.setAttribute('data-playing', 'true');
    centerPlayIcon.className = 'fas fa-pause';
  });
  
  video.addEventListener('pause', function() {
    video.setAttribute('data-playing', 'false');
    centerPlayIcon.className = 'fas fa-play';
  });
  
  // Video ended - reset to play icon
  video.addEventListener('ended', function() {
    video.setAttribute('data-playing', 'false');
    centerPlayIcon.className = 'fas fa-play';
  });
});

// Existing load more functionality
let skip = 8;
const excludeId = "<%= data.id %>";
const grid = document.getElementById("suggestGrid");
const btn = document.getElementById("loadMore");

btn.addEventListener("click", async () => {
  btn.innerHTML = '<span>Loading...</span><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="spin"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>';
  btn.disabled = true;
  
  // Add spinning animation to SVG
  const svg = btn.querySelector('svg');
  svg.style.animation = 'spin 1s linear infinite';
  
  const style = document.createElement('style');
  style.textContent = `
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
  `;
  document.head.appendChild(style);

  try {
    const res = await fetch(
      `/api/suggested?excludeId=${excludeId}&skip=${skip}`
    );
    const data = await res.json();

    if (data.length === 0) {
      btn.innerHTML = '<span>No more videos</span>';
      svg.style.display = 'none';
      return;
    }

    data.forEach(item => {
      const rating = (Math.random() * 2 + 8).toFixed(1);
      const a = document.createElement("a");
      a.href = `/movie/${item.id}`;
      a.className = "s-card";
      a.innerHTML = `
        <div class="rating">${rating}</div>
        <img src="${item.img}" loading="lazy" alt="${item.hadding}">
        <p>${item.hadding}</p>
      `;
      grid.appendChild(a);
    });

    skip += 8;
    btn.innerHTML = '<span>See More</span><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14M5 12l7 7 7-7"/></svg>';
    btn.disabled = false;
    svg.style.animation = '';
  } catch (error) {
    console.error("Error loading suggestions:", error);
    btn.innerHTML = '<span>Error loading. Try again</span>';
    btn.disabled = false;
    svg.style.animation = '';
  }
});
			
</script>

</body>
</html>